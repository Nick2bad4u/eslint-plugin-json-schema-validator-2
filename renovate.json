{
  "extends": [
    "config:base",
    ":preserveSemverRanges",
    ":disableDependencyDashboard"
  ],
  "packageRules": [
    {
      "automerge": true,
      "updateTypes": ["minor", "patch", "pin", "digest"]
    },
    {
      "automerge": true,
      "depTypeList": ["devDependencies"]
    },
    {
      "automerge": true,
      "matchManagers": ["github-actions", "devcontainer"]
    }
  ]
}
